generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id String @id @default(uuid()) @map("user_id") @db.Uuid

  email        String  @unique
  firstName    String  @map("first_name")
  lastName     String  @map("last_name")
  passwordHash String  @map("password_hash")
  status       Int     @default(1)
  isKiosk      Boolean @default(false) @map("is_kiosk")

  roles         UserRole[]
  refreshTokens RefreshToken[]
  activities    AuditLog[]     @relation("AuditActor")

  deleted   Boolean   @default(false)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  @@map("users")
}

model Role {
  id String @id @default(uuid()) @map("role_id") @db.Uuid

  code        String  @unique
  name        String
  description String?
  isSystem    Boolean @default(false) @map("is_system")
  isActive    Boolean @default(true) @map("is_active")

  userRoles       UserRole[]
  rolePermissions RolePermission[]

  deleted   Boolean   @default(false)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  @@map("roles")
}

model Permission {
  id String @id @default(uuid()) @map("permission_id") @db.Uuid

  code        String  @unique
  resource    String
  action      String
  description String?

  rolePermissions RolePermission[]

  deleted   Boolean   @default(false)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  @@map("permissions")
}

model UserRole {
  id String @id @default(uuid()) @map("user_role_id") @db.Uuid

  userId String @map("user_id") @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  roleId String @map("role_id") @db.Uuid
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
  @@map("user_roles")
}

model RolePermission {
  id String @id @default(uuid()) @map("role_permission_id") @db.Uuid

  roleId       String     @map("role_id") @db.Uuid
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permissionId String     @map("permission_id") @db.Uuid
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
  @@map("role_permissions")
}

model RefreshToken {
  id String @id @default(uuid()) @map("refresh_token_id") @db.Uuid

  tokenHash         String   @unique @map("token_hash")
  expiresAt         DateTime @map("expires_at") @db.Timestamptz(6)
  replacedByTokenId String?  @map("replaced_by_token_id") @db.Uuid
  userAgent         String?  @map("user_agent")
  ipAddress         String?  @map("ip_address")

  userId String @map("user_id") @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  revoked   Boolean   @default(false)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  revokedAt DateTime? @map("revoked_at") @db.Timestamptz(6)

  @@index([userId, revokedAt])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model AuditLog {
  id String @id @default(uuid()) @map("audit_log_id") @db.Uuid

  action     String
  entityType String @map("entity_type")
  entityId   String @map("entity_id")
  before     Json?
  after      Json?
  metadata   Json?

  actorUserId String? @map("actor_user_id") @db.Uuid
  actor       User?   @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([entityType, entityId, createdAt])
  @@index([actorUserId, createdAt])
  @@map("audit_logs")
}

model Company {
  id String @id @default(uuid()) @map("company_id") @db.Uuid

  name               String  @db.VarChar(255)
  registrationNumber String? @map("registration_number")
  address            String?
  logoUrl            String? @map("logo_url")
  financialYearStart Int?    @map("financial_year_start")
  payFrequency       String? @map("pay_frequency")
  currency           String  @default("PGK")

  deleted   Boolean   @default(false)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  @@map("companies")
}
