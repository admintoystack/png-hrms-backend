{
  "name": "png-hrms-backend",
  "version": "0.0.1",
  "description": "PNG HRMS Backend",
  "scripts": {
    "tsc": "tsc --traceResolution",
    "dev": "NODE_PATH=$NODE_PATH:./src ts-node-dev --respawn --transpile-only ./src/server.ts",
    "build": "NODE_PATH=$NODE_PATH:./src tsc",
    "prod": "NODE_PATH=$NODE_PATH:./src tsc && node ./build/src/server.js",
    "postinstall": "npx prisma generate"
  },
  "devDependencies": {
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/graphql-depth-limit": "^1.1.6",
    "@types/jsonwebtoken": "^9.0.1",
    "@types/pg": "^8.20.0",
    "prettier": "^3.8.3",
    "prettier-plugin-prisma": "^5.0.0"
  },
  "dependencies": {
    "@apollo/datasource-rest": "^6.4.1",
    "@apollo/server": "^5.5.0",
    "@as-integrations/express5": "^1.1.2",
    "@graphql-tools/schema": "^10.0.33",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@types/node": "^25.6.0",
    "body-parser": "^2.2.2",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "graphql": "^16.13.2",
    "graphql-depth-limit": "^1.1.0",
    "graphql-middleware": "^6.1.35",
    "graphql-shield": "^7.6.5",
    "graphql-upload-ts": "^2.2.0",
    "jsonwebtoken": "^9.0.3",
    "link-module-alias": "^1.2.0",
    "module-alias": "^2.3.4",
    "pg": "^8.20.0",
    "prisma": "^7.8.0",
    "prisma-extension-pagination": "^0.7.6",
    "prisma-soft-delete": "^1.0.2",
    "short-unique-id": "^5.3.2",
    "ts-node": "^10.7.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3",
    "winston": "^3.19.0"
  },
  "_moduleAliases": {
    "datasources": "src/datasources",
    "interfaces": "src/interfaces",
    "schema": "src/schema",
    "utils": "src/utils",
    "permissions": "src/permissions"
  },
  "license": "ISC",
  "prisma": {
    "seed": "node -r module-alias/register -r ts-node/register prisma/seed.ts"
  }
}
